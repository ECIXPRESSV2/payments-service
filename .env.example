# --- Base de datos (PostgreSQL en NeonDB) ---
DATABASE_URL=                        # NeonDB, con sslmode=require

# --- Bus de eventos (RabbitMQ en CloudAMQP) ---
RABBITMQ_URL=                        # CloudAMQP, formato amqps://user:pass@host/vhost

# --- Pasarela de pagos Wompi (sandbox) ---
WOMPI_PUBLIC_KEY=                    # pub_test_...
WOMPI_PRIVATE_KEY=                   # prv_test_...
WOMPI_EVENTS_SECRET=                 # secreto de eventos para validar webhooks
WOMPI_INTEGRITY_SECRET=              # secreto de integridad para firmar transacciones

# --- Comisiones por defecto al crear un negocio ---
DEFAULT_PLATFORM_FEE_PERCENT=5
DEFAULT_PEAK_FEE_PERCENT=3

# --- General ---
NODE_ENV=development
PORT=3004
TZ=America/Bogota
